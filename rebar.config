%% -*- mode: erlang -*-
%% rebar3 umbrella for hecate-dronex.
%%
%% ONE repository, TWO releases, a hard wall between them:
%%
%%   dronex_edge — the site brain. Runs at a street/area/site. Consumes
%%                 airspace.contact_observed facts, fuses them into tracks,
%%                 alerts. Contains ZERO simulation code.
%%   dronex_sim  — the driver. Simulates drones, weather, sensors. Emits the
%%                 same facts a real sensor would, and scores fusion against
%%                 ground truth. Includes the edge apps so a full loop runs on
%%                 one dev node.
%%
%% Apps are grouped on disk under apps/{shared,edge,sim}/* so the separation
%% screams. project_app_dirs below is what makes rebar3 discover that layout.

{erl_opts, [debug_info, warnings_as_errors]}.

{project_app_dirs, [
    "apps/shared/*",
    "apps/edge/*",
    "apps/sim/*",
    "."                 %% the root shell app (src/)
]}.

{deps, [
    %% Service substrate (mesh identity, boot, health). Pinned to a tag, not a
    %% branch: branch deps froze in the parksim CI/Docker cache. v0.3.1 carries
    %% the deferred+retry, cert-decoupled mesh connect.
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git", {tag, "v0.3.1"}}},

    %% Top-level override of reckon_db's transitive khepri (does_path_match
    %% delete-crash fix). Fork vsn stays 0.17.2 so reckon_db's exact pin holds.
    {khepri, {git, "https://codeberg.org/reckon-db-org/khepri.git", {tag, "v0.17.2-reckon1"}}},

    {reckon_db,    "~> 4.0"},
    {evoq,         "~> 1.15"},
    {reckon_evoq,  "~> 2.3"},
    {reckon_gater, "~> 3.0"},

    {cowboy,  "~> 2.12.0"},
    {esqlite, "~> 0.8.0"},
    {jsx,     "~> 3.1"}
]}.

{relx, [
    %% --- dronex_edge: the lean production site brain (NO sim apps) ---
    {release, {dronex_edge, "0.1.0"}, [
        hecate_dronex,
        dronex_contracts,
        fuse_airspace,

        hecate_om, reckon_db, evoq, reckon_evoq,
        ssl, jsx
    ]},

    %% --- dronex_sim: edge brain + the driver, full loop on one node ---
    {release, {dronex_sim, "0.1.0"}, [
        hecate_dronex,
        dronex_contracts,
        fuse_airspace,

        simulate_airspace,
        observe_remote_id,
        query_detection_quality,

        hecate_om, reckon_db, evoq, reckon_evoq,
        ssl, jsx
    ]},

    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_dronex]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config_src, "config/sys.config.src"},
            {vm_args_src,    "config/vm.args.src"}
        ]}
    ]}
]}.
