%% Dev config for `rebar3 shell` and the dronex_sim release running locally.
%% No mesh here: when no macula client is configured, dronex_fact_bus falls
%% back to a local in-node (pg) transport, so the full loop still runs.
[
    {hecate_dronex, [
        {site_id,    "leuven-perimeter"},
        {role,       sim},          %% sim | edge
        {http_port,  8474},
        {time_scale, 10.0},         %% compress sim time 10x for demos
        {seed,       0},
        {scenario,   "perimeter_probe"}
    ]},

    %% evoq adapter wiring: dispatch + subscribe + snapshot via reckon_evoq.
    {evoq, [
        {event_store_adapter,    reckon_evoq_adapter},
        {subscription_adapter,   reckon_evoq_adapter},
        {snapshot_store_adapter, reckon_evoq_adapter}
    ]},

    {kernel, [
        {logger_level, info}
    ]}
].
